# name: test/sql/pac_derived.test
# description: Test PAC derived_pu counter storage and read-time finalization
# group: [pac]

require pac

statement ok
SET pac_mi = 0;

statement ok
SET pac_seed = 42;

statement ok
SET threads = 1;

# ==========================================
# Setup: PU table with protected column
# ==========================================

statement ok
CREATE PU TABLE scores (id INT, grp INT, value INT, PAC_KEY(id), protected(value));

statement ok
INSERT INTO scores VALUES (1, 1, 10), (2, 1, 20), (3, 2, 30);

# ==========================================
# 1. CTAS with aggregate → derived_pu with counters
# ==========================================

statement ok
CREATE TABLE mv AS SELECT grp, SUM(value) AS total FROM scores GROUP BY grp;

# With pac_rewrite=false, we should see raw counter lists (LIST<DOUBLE>)
statement ok
SET pac_rewrite = false;

# The total column should be a list type
query I
SELECT typeof(total) FROM mv LIMIT 1;
----
FLOAT[]

statement ok
SET pac_rewrite = true;

# With pac_rewrite=true, SELECT should return noised scalars via pac_finalize injection
# pac_mi=0 means no noise, so we should get the exact mean of counters
query II
SELECT * FROM mv ORDER BY grp;
----
1	30.0
2	30.0

# ==========================================
# 2. Verify pac_finalize works on the counters
# ==========================================

# Direct query for comparison (also with pac_mi=0, no noise)
query II
SELECT grp, SUM(value) AS total FROM scores GROUP BY grp ORDER BY grp;
----
1	30.0
2	30.0

# ==========================================
# 3. Non-aggregate CTAS should NOT be derived_pu
# ==========================================

statement ok
SET pac_rewrite = false;

statement ok
SET pac_check = false;

statement ok
CREATE TABLE copy_scores AS SELECT id, grp, value FROM scores;

# copy_scores should have regular INT columns, not LIST<DOUBLE>
query I
SELECT typeof(value) FROM copy_scores LIMIT 1;
----
INTEGER

statement ok
SET pac_rewrite = true;

statement ok
SET pac_check = true;
