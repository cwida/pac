# name: test/sql/pac_derived.test
# description: Test PAC derived_pu counter storage and read-time finalization
# group: [pac]

require pac

statement ok
SET pac_mi = 0;

statement ok
SET pac_seed = 42;

statement ok
SET threads = 1;

# ==========================================
# Setup: PU table with protected column
# ==========================================

statement ok
CREATE PU TABLE scores (id INT, grp INT, value INT, PAC_KEY(id), protected(value));

statement ok
INSERT INTO scores VALUES (1, 1, 10), (2, 1, 20), (3, 2, 30);

# ==========================================
# 1. Write path: CTAS stores counters
# ==========================================

statement ok
CREATE TABLE mv AS SELECT grp, SUM(value) AS total FROM scores GROUP BY grp;

# With pac_rewrite=false, column should be LIST type (raw counters)
statement ok
SET pac_rewrite = false;

query I
SELECT typeof(total) FROM mv LIMIT 1;
----
FLOAT[]

statement ok
SET pac_rewrite = true;

# ==========================================
# 2. Read path: pac_finalize injected automatically
# ==========================================

# With pac_mi=0 (no noise), finalized values should be exact
# True values: grp 1 = 10+20 = 30, grp 2 = 30
# Counter correction (2x): grp 1 = 60, grp 2 = 60
query IR rowsort
SELECT grp, total FROM mv;
----
1	60.0
2	60.0

# Verify result has 2 rows (no crash, correct execution)
query I
SELECT count(*) FROM mv;
----
2

# ==========================================
# 3. Direct query should match (pac_mi=0)
# ==========================================

query IR rowsort
SELECT grp, SUM(value) AS total FROM scores GROUP BY grp;
----
1	60
2	60

# ==========================================
# 4. Manual pac_finalize also works
# ==========================================

statement ok
SET pac_rewrite = false;

query IR rowsort
SELECT grp, pac_finalize(total) FROM mv;
----
1	60.0
2	60.0

statement ok
SET pac_rewrite = true;

# ==========================================
# 5. Noise applied with pac_mi > 0
# ==========================================

statement ok
SET pac_mi = 1;

# Results should be returned without error (2 rows with noise)
query I
SELECT count(*) FROM mv;
----
2

# ==========================================
# 6. Non-aggregate CTAS should NOT be derived_pu
# ==========================================

statement ok
SET pac_mi = 0;

statement ok
SET pac_rewrite = false;

statement ok
SET pac_check = false;

statement ok
CREATE TABLE copy_scores AS SELECT id, grp, value FROM scores;

# copy_scores should have regular INT columns, not LIST<FLOAT>
query I
SELECT typeof(value) FROM copy_scores LIMIT 1;
----
INTEGER

statement ok
SET pac_rewrite = true;

statement ok
SET pac_check = true;

# ==========================================
# 7. ORDER BY works on derived_pu tables
# ==========================================

statement ok
SET pac_mi = 0;

query IR
SELECT grp, total FROM mv ORDER BY grp;
----
1	60.0
2	60.0

# ==========================================
# 8. WHERE clause works on derived_pu tables
# ==========================================

query IR
SELECT grp, total FROM mv WHERE grp = 1;
----
1	60.0

# ==========================================
# 9. Subquery on derived_pu tables
# ==========================================

query I
SELECT (SELECT total FROM mv WHERE grp = 1) = (SELECT total FROM mv WHERE grp = 1);
----
true

# ==========================================
# 10. Stable noise: same counters = same result across reads
# ==========================================

statement ok
SET pac_mi = 1;

statement ok
SET pac_seed = 42;

query I
SELECT count(*) FROM mv;
----
2

# ==========================================
# 8. pac_mi=0 counters have zero variance -> no noise
# ==========================================

# The counters were created with pac_mi=0, meaning all 64 subsamples
# agree perfectly. pac_finalize computes variance=0 -> delta=0 -> no noise,
# regardless of the current pac_mi setting at read time.
# (This is expected behavior: noise calibration depends on counter variance)

statement ok
SET pac_mi = 0;

statement ok
SET pac_seed = 99;

query IR rowsort
SELECT grp, total FROM mv;
----
1	60.0
2	60.0
